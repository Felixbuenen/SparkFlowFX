*.exe
*.out
*.app
*.pdb
*.ilk
*.exp

# Generated SPIR-V (shaders compile into the build tree)
*.spv

# Dependency manager (vcpkg; FetchContent lands inside build/)
vcpkg_installed/

# Visual Studio
.vs/
*.user
*.vcxproj.user
*.suo

# VS Code
.vscode/

